# =============================================================================
# AI Memory Companion — variables de entorno
# =============================================================================
# En Vercel: Settings → Environment Variables → activar Production + Preview.
# IMPORTANTE: las NEXT_PUBLIC_* se insertan en el bundle durante `npm run build`.
# Tras cambiarlas en Vercel debes hacer REDEPLOY (no basta guardar).
# =============================================================================

# Firebase (cliente — obligatorias)
# Firebase Console → Configuración del proyecto → Tus apps → SDK web
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Gemini (solo servidor — sin prefijo NEXT_PUBLIC)
GEMINI_API_KEY=

# Opcional
NEXT_PUBLIC_APP_URL=http://localhost:3000
